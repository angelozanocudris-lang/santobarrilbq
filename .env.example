# ============================================
# VARIABLES DE ENTORNO - SANTO BARRIL
# ============================================
# Copia este archivo como `.env` y completa los valores.
# En Vercel: configurar como Environment Variables.

# --- Supabase (cliente - visibles en el navegador) ---
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu_publishable_key_aqui
VITE_SUPABASE_PROJECT_ID=tu_project_id

# --- Supabase (servidor - NO se exponen al navegador) ---
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_publishable_key_aqui
SUPABASE_PROJECT_ID=tu_project_id
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- Autenticación interna ---
# PIN numérico para acceder al panel de administrador
ADMIN_PIN=1234
# PIN numérico para acceder al panel de mesera
WAITER_PIN=5678
# Secreto aleatorio (mínimo 32 caracteres) para firmar sesiones
# Genera uno con: openssl rand -hex 32
ADMIN_SESSION_SECRET=cambia_esto_por_una_cadena_aleatoria_larga
